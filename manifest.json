{
  "manifest_version": 3,
  "name": "ratpack",
  "version": "0.1.1",
  "description": "Overlay multiple Squadrats users' progress on the same route-planner map.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "js": ["src/config.js", "src/storage.js", "src/colors.js", "src/fetcher.js", "src/cache.js", "src/throttle.js", "src/main.js"],
      "matches": ["*://*.brouter.de/*", "https://*.strava.com/*"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/page-renderer.js"],
      "matches": ["*://*.brouter.de/*", "https://*.strava.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ratpack"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ratpack@local",
      "strict_min_version": "109.0",
      "update_url": "https://raw.githubusercontent.com/aliaksei135/ratpack/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
